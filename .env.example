NODE_ENV=development

# Gere um segredo forte em produção, ex.: openssl rand -base64 48
JWT_SECRET=troque_essa_chave_em_dev_use_segredo_de_48_bytes_em_prod
JWT_EXPIRES_IN=8h

# Nome e duração do cookie de sessão (segundos)
AUTH_COOKIE_NAME=operadesk_session
AUTH_COOKIE_MAX_AGE=28800

# PostgreSQL
# O docker-compose mapeia o container 5432 para a porta 5433 do host.
# Use 5433 aqui se você roda o Next fora do Docker (ex.: npm run dev:full).
DB_HOST=localhost
DB_PORT=5432
DB_USER=operadesk
DB_PASSWORD=operadesk
DB_NAME=operadesk
DB_POOL_MAX=10

# Usada pelo node-pg-migrate (scripts db:migrate*)
DATABASE_URL=postgres://operadesk:operadesk@localhost:5432/operadesk
